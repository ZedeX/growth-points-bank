{
  "name": "@gpb/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@gpb/shared": "workspace:*",
    "argon2": "^0.40.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "jose": "^5.6.0",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pino": "^9.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsc-alias": "^1.8.0"
  }
}
