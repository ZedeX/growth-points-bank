# Database (SQLite file path)
DATABASE_URL=data/gpb.db

# Auth secrets (generate with: openssl rand -hex 32)
PARENT_JWT_SECRET=change-me-parent-secret-32-chars-min
CHILD_JWT_SECRET=change-me-child-secret-32-chars-min
AUTH_HMAC_SECRET=change-me-hmac-secret-32-chars-min

# Encryption (generate with: openssl rand -base64 32)
DATA_ENCRYPTION_KEY=change-me-base64-encoded-32-byte-key

# Server
PORT=3000
NODE_ENV=development
ENABLE_SCHEDULER=true

# Frontend
VITE_API_URL=http://localhost:3000
